# TrafficGuard AI — Environment Configuration Example
# Copy this file to .env and fill in the credentials before running locally or deploying.

# --- General System Settings ---
PORT=5000
NODE_ENV=development

# --- Database Config ---
# Specify your MongoDB connection URI (e.g. MongoDB Atlas connection string).
# If left blank, the system will attempt to use MongoMemoryServer in local development.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/traffic_db?retryWrites=true&w=majority

# --- AI & LLM Service Keys ---
# API key for Gemini LLM legal analytics (required for violation explanation generation)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_GENAI_KEY=your_google_genai_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- Python AI Service URL ---
# The URL where the backend can communicate with the Python ML detection engine
PYTHON_SERVICE_URL=http://127.0.0.1:8001
PYTHON_AI_SERVICE_URL=http://127.0.0.1:8001

# --- Frontend Config (Vite) ---
# The backend API URL for the React dashboard frontend.
# Set this to the production backend URL when deploying.
VITE_API_URL=http://localhost:5000
